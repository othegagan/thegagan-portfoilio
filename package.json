{
  "name": "thegagan-portfoilio",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.3.1",
      "zod": "^4.3.6",
      "lucide-react": "^1.7.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "sonner": "^2.0.7",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.2.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:web": "bun run --filter web dev",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@thegagan-portfoilio/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@thegagan-portfoilio/config": "workspace:*",
    "typescript": "^6",
    "ultracite": "7.3.2"
  },
  "packageManager": "bun@1.3.11"
}
